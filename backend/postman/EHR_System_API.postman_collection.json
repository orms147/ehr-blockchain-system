{
    "info": {
        "name": "EHR System API",
        "description": "API collection for EHR Blockchain System Backend\n\nBase URL: http://localhost:3001",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
        {
            "key": "baseUrl",
            "value": "http://localhost:3001",
            "type": "string"
        },
        {
            "key": "token",
            "value": "",
            "type": "string"
        },
        {
            "key": "walletAddress",
            "value": "0x71Ade4593711749Ea08a3552A59a832c1B40a955",
            "type": "string"
        }
    ],
    "item": [
        {
            "name": "Health",
            "item": [
                {
                    "name": "Health Check",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{baseUrl}}/health",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "health"
                            ]
                        }
                    }
                }
            ]
        },
        {
            "name": "Authentication",
            "item": [
                {
                    "name": "Get Nonce",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{baseUrl}}/api/auth/nonce/{{walletAddress}}",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "auth",
                                "nonce",
                                "{{walletAddress}}"
                            ]
                        }
                    }
                },
                {
                    "name": "Login",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"walletAddress\": \"{{walletAddress}}\",\n  \"message\": \"Sign this message to login to EHR System.\\n\\nNonce: YOUR_NONCE_HERE\\nTimestamp: 1234567890\",\n  \"signature\": \"0xYOUR_SIGNATURE_HERE\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/auth/login",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "auth",
                                "login"
                            ]
                        }
                    }
                },
                {
                    "name": "Register Public Key",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"publicKey\": \"0x04abc123...your_public_key\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/auth/register-pubkey",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "auth",
                                "register-pubkey"
                            ]
                        }
                    }
                },
                {
                    "name": "Get My Info",
                    "request": {
                        "method": "GET",
                        "header": [
