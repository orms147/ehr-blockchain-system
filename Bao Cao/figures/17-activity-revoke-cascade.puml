@startuml act-thu-hoi-cascade
title act Quy trình thu hồi cascade

|Bệnh nhân|
start
:Mở Nhật ký truy cập → tìm Bác sĩ A;
:Bấm "Thu hồi" + xác nhận;
:Ký RevokePermit + vân tay;

|Hệ thống|
:Verify chữ ký + submit sponsored tx;

|Blockchain|
:Mark Consent(A) active=false;
:Emit ConsentRevoked event;

|Hệ thống|
:Subgraph index event\n→ handleConsentRevoked;
:Tầng 1: revoke KeyShare\nrows có sender=A;
:Tầng 2: query DelegationAccessLog\nWHERE byDelegatee=A → danh sách B/C/...;

while (Mỗi người nhận derived\nB, C, ... trong log)
  if (B chỉ có quyền\nqua A — không có direct grant?) then ([Có])
    :Cascade revoke ALL KeyShare\nrows cho B;
    :Update Consent table → revoked;
    :Push WebSocket cho B;
  else ([Không — B có direct grant\nFootgun #1 fix])
    :SKIP — B's direct grant\nkhông bị touch;
  endif
endwhile

|Bác sĩ B|
:Refresh dashboard → mở hồ sơ;

|Hệ thống|
:Gate canAccess trên blockchain;

|Blockchain|
if (recordDelegationSource[B] = A?) then ([Có])
  if (A đã revoked?) then ([Có])
    :Return false;
    |Hệ thống|
    :Trả 403 Forbidden;
    stop
  endif
else ([Không — = address(0) sau\nFootgun #1 clear])
  :Check Consent của B → còn active;
  :Return true;
  |Hệ thống|
  :Trả encryptedPayload;
  |Bác sĩ B|
  :B vẫn xem được hồ sơ\n(direct grant survive);
  stop
endif

@enduml
