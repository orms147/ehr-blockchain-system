  "main": "index.ts",
  "scripts": {
    "preflight": "node scripts/preflight.cjs",
    "start": "npm run preflight && expo start --dev-client --port 8081",
    "start:clear": "npm run preflight && expo start --dev-client --clear --port 8081",
    "android": "npm run preflight && expo run:android --port 8081",
    "android:dev": "npm run preflight && expo run:android --port 8081",
    "ios": "npm run preflight && expo run:ios",
    "web": "npm run preflight && expo start --web",
    "type-check": "tsc --noEmit",
    "android:attach": "npm run preflight && expo run:android --no-bundler"
  },
