@startuml act-nguoi-than-tin-cay
title act Quy trình Người thân tin cậy

|Bệnh nhân|
start
:Mở Người thân tin cậy → bấm "Thêm";
:Paste ví TC + nhập nhãn ("Mẹ", "Con trai");

|Hệ thống|
if (Ví hợp lệ + khác Bệnh nhân?) then ([Không])
  :Highlight error;
  stop
else ([Có])
endif

|Bệnh nhân|
:Ký TrustedContactPermit + vân tay;

|Hệ thống|
:Submit sponsored tx;

|Blockchain|
:isTrustedContact[P][TC] = true;
:Emit TrustedContactSet event;

|Hệ thống|
if (TC đã đăng nhập app\n+ có khoá mã hoá?) then ([Chưa])
  :Báo "TC chưa kích hoạt khoá —\nyêu cầu họ đăng nhập trước";
  stop
else ([Đã có])
endif

:Mã hoá khoá AES của mọi hồ sơ\ncho TC's public key;
:Lưu KeyShare rows\nsource='trusted-contact';

|Người thân tin cậy|
:TC đăng nhập app;
:Mở hồ sơ Bệnh nhân;

|Hệ thống|
:Gate canAccess trên blockchain;

|Blockchain|
if (isTrustedContact[P][TC] = true?) then ([Có])
  :Return true ngay\n(Footgun #2 fix);
else ([Không])
  :Return false;
  |Hệ thống|
  :Trả 403 Forbidden;
  stop
endif

|Hệ thống|
:Trả encryptedPayload;

|Người thân tin cậy|
:Giải mã NaCl box → khoá AES;
:Tải IPFS + giải mã AES-GCM;
:Hiển thị hồ sơ;

|Bệnh nhân|
:(Phase C — về sau) Thu hồi TC;
:Ký TrustedContactPermit(active=false);

|Hệ thống|
:Submit sponsored tx;

|Blockchain|
:isTrustedContact[P][TC] = false;
:Emit TrustedContactRevoked;

|Hệ thống|
:Cascade revoke KeyShare rows\nsource='trusted-contact';

|Người thân tin cậy|
:Mở hồ sơ sau khi bị thu hồi;
:canAccess trả false → 403;
note right
  ⚠ Limitation: TC vẫn có thể giải mã
  OFFLINE nếu local cache còn —
  envelope encryption không un-share
  được data đã đọc trước đó.
end note
stop

@enduml
