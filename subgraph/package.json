{
  "name": "ehr-subgraph",
  "version": "0.1.0",
  "description": "The Graph subgraph for EHR contracts on Arbitrum Sepolia",
  "scripts": {
    "codegen": "graph codegen",
    "build": "graph build",
    "create-local": "graph create --node http://localhost:8020/ ehr-local",
    "remove-local": "graph remove --node http://localhost:8020/ ehr-local",
    "deploy-local": "graph deploy --node http://localhost:8020/ --ipfs http://localhost:5001 ehr-local",
    "deploy-studio": "graph deploy --studio ehr-arbsepolia",
    "deploy-hosted": "graph deploy --product hosted-service <GITHUB_USER>/ehr-arbsepolia"
  },
  "devDependencies": {
    "@graphprotocol/graph-cli": "0.85.0",
    "@graphprotocol/graph-ts": "0.35.1"
  }
}
