# ===== Subgraph (The Graph Studio) — reference for deploy =====
# The subgraph reads addresses/startBlocks from subgraph.yaml (NOT a .env at runtime).
# After every contract redeploy, update the 4 dataSources in subgraph.yaml:
#   RecordRegistry, EHRSystem(=EHRSystemSecure), ConsentLedger, AccessControl
#   -> each: source.address + source.startBlock   (there is NO DoctorUpdate dataSource)

# Studio deploy key (from thegraph.com/studio). Used by `graph auth`.
GRAPH_DEPLOY_KEY=YOUR_STUDIO_DEPLOY_KEY

# Studio subgraph slug (the project name in Studio).
SUBGRAPH_SLUG=ehr-arbsepolia

# Deploy steps:
#   npm install && npm run codegen && npm run build
#   npx graph auth $GRAPH_DEPLOY_KEY
#   npm run deploy-studio
# Then copy the resulting query URL into backend/.env SUBGRAPH_URL and
# mobile/.env EXPO_PUBLIC_SUBGRAPH_URL.
