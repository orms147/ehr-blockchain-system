# ===== Backend .env (EHR DATN) — copy to backend/.env and fill in =====
# Vars verified against backend/src + prisma/schema.prisma (2026-06-18).
# CRITICAL = lose this and data/access breaks.

# --- Database (Prisma / Postgres, e.g. Neon) --- CRITICAL
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"

# --- Server ---
NODE_ENV=development            # "production" makes secret checks fail-fast (e.g. CREDENTIAL_ENCRYPTION_KEY)
PORT=4000
ENABLE_TEST_ROUTES=false        # "true" ONLY in local dev — mounts /api/test/* (forge JWT / reset-db). Never in shared/prod.
LOG_LEVEL=info
FRONTEND_URL=http://localhost:8081   # CORS allow-origin (mobile dev server / web)

# --- Auth (JWT) --- CRITICAL
JWT_SECRET=CHANGE_ME_long_random_secret
JWT_EXPIRES_IN=7d

# --- Blockchain (Arbitrum Sepolia, chainId 421614) --- CRITICAL
RPC_URL=https://arb-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
CHAIN_ID=421614
# 5 contract addresses — FILL AFTER REDEPLOY (old ones are dead, seed lost):
ACCESS_CONTROL_ADDRESS=0x...
CONSENT_LEDGER_ADDRESS=0x...
RECORD_REGISTRY_ADDRESS=0x...
EHR_SYSTEM_ADDRESS=0x...
DOCTOR_UPDATE_ADDRESS=0x...

# --- Relayer / gas sponsor --- CRITICAL (hot key — keep secret)
SPONSOR_PRIVATE_KEY=0x...        # funded EOA that broadcasts patient *BySig txs

# --- Credential encryption (DoctorCredential.encryptedData) --- CRITICAL
# If unset, the server uses an EPHEMERAL key and all stored credentials become
# undecryptable after a restart. Use a fixed 64-hex (32-byte) value.
CREDENTIAL_ENCRYPTION_KEY=CHANGE_ME_64_hex_chars

# --- IPFS (Pinata) ---
PINATA_JWT=eyJ...               # only used by backend for org-license upload
PINATA_GATEWAY=https://YOUR-GATEWAY.mypinata.cloud

# --- Subgraph (The Graph Studio) ---
SUBGRAPH_URL=https://api.studio.thegraph.com/query/<id>/ehr-arbsepolia/<version>
SUBGRAPH_POLL_MS=30000

# --- RPC tuning (optional; sane defaults in code) ---
ROLE_CACHE_TTL_MS=600000
RPC_TRANSPORT_RETRIES=0
RPC_TRANSPORT_RETRY_DELAY_MS=1000
RPC_CATCHUP_DELAY_MS=1000
RPC_CATCHUP_MAX_BLOCKS=2000
RPC_LOGS_CHUNK_SIZE=500
RPC_WATCH_POLL_MS=8000
