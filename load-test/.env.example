# Copy to `.env` và fill values trước khi chạy k6. KHÔNG commit `.env`.
#
# BASE_URL — backend đang lắng nghe đâu
BASE_URL=http://localhost:3001

# PATIENT_JWT — JWT của test user (patient role). Lấy bằng cách login mobile
# rồi inspect AsyncStorage / SecureStore key 'auth_token', hoặc xem
# Network DevTools header Authorization khi mobile gọi /api/records/my.
PATIENT_JWT=

# DOCTOR_JWT — JWT của verified doctor (cho scenarios cần test cross-role,
# optional cho scenarios hiện tại).
DOCTOR_JWT=

# CID_HASH — 1 cidHash của record patient ở trên có quyền đọc.
# Lấy từ output GET /api/records/my của PATIENT_JWT.
CID_HASH=
