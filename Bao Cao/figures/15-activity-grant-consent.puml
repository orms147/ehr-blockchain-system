@startuml act-cap-quyen
title act Quy trình cấp quyền truy cập

|Bệnh nhân|
start
:Mở chi tiết hồ sơ → bấm "Chia sẻ";
:Nhập ví bác sĩ + thời hạn\n+ cho phép uỷ quyền tiếp;

|Hệ thống|
if (Định dạng ví hợp lệ?) then ([Không])
  :Highlight lỗi định dạng;
  stop
else ([Có])
endif

if (Ví trùng với Bệnh nhân?) then ([Có])
  :Báo lỗi "Không thể tự chia sẻ";
  stop
else ([Không])
endif

if (Bác sĩ đã có quyền\ndài hạn hơn?) then ([Có])
  :Cảnh báo "Đã có quyền\ndài hạn hơn — thu hồi trước";
  stop
else ([Không])
endif

|Bệnh nhân|
:Bấm "Chia sẻ" + ký bằng vân tay;

|Hệ thống|
:Verify chữ ký EIP-712\n+ gửi sponsored tx;

|Blockchain|
if (Giao dịch thành công?) then ([Không])
  |Hệ thống|
  :Báo lỗi tx revert;
  stop
else ([Có])
endif

:Lưu Consent + clear delegation source\n(Footgun #1 fix);
:Emit ConsentGranted event;

|Hệ thống|
:Mã hoá khoá AES cho bác sĩ\ncho mọi phiên bản trong chain;
:Subgraph index event → mirror DB;
:Push WebSocket tới bác sĩ;

|Bệnh nhân|
:Hiển thị "Đã cấp quyền";
stop

@enduml
