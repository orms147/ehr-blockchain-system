# ===== Mobile .env (Expo) — copy to mobile/.env and fill in =====
# Expo inlines EXPO_PUBLIC_* into the client bundle (do NOT put secrets you don't
# want shipped). Vars verified against mobile/src (2026-06-18).

# --- Backend API ---
EXPO_PUBLIC_API_URL=http://10.0.2.2:3001   # Android emulator alias; use LAN IP on a real device

# --- Auth (Web3Auth) --- required to log in
EXPO_PUBLIC_WEB3AUTH_CLIENT_ID=YOUR_WEB3AUTH_CLIENT_ID
EXPO_PUBLIC_WEB3AUTH_REDIRECT_URL=erhsystem://auth

# --- Blockchain (Arbitrum Sepolia) — FILL AFTER REDEPLOY ---
EXPO_PUBLIC_RPC_URL=https://arb-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
EXPO_PUBLIC_CHAIN_ID=421614
EXPO_PUBLIC_ACCESS_CONTROL_ADDRESS=0x...
EXPO_PUBLIC_CONSENT_LEDGER_ADDRESS=0x...
EXPO_PUBLIC_RECORD_REGISTRY_ADDRESS=0x...
EXPO_PUBLIC_EHR_SYSTEM_ADDRESS=0x...
EXPO_PUBLIC_DOCTOR_UPDATE_ADDRESS=0x...

# --- IPFS (Pinata) — client uploads ciphertext directly ---
EXPO_PUBLIC_PINATA_JWT=eyJ...
EXPO_PUBLIC_PINATA_GATEWAY=https://YOUR-GATEWAY.mypinata.cloud

# --- Subgraph (mobile queries The Graph directly) ---
EXPO_PUBLIC_SUBGRAPH_URL=https://api.studio.thegraph.com/query/<id>/ehr-arbsepolia/<version>

# --- Observability / flags (optional) ---
EXPO_PUBLIC_SENTRY_DSN=
