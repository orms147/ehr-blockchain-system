# ===== Contracts .env (Foundry) — copy to contracts/.env and fill in =====
# Used by script/DeployAll.s.sol and the forge CLI.
# Old deployment is dead (wallet seed lost) -> redeploy with a NEW wallet.

# Broadcasting EOA. MUST equal the --private-key used on the CLI, because DeployAll
# makes this address ConsentLedger admin = RecordRegistry deployer = AccessControl Ministry.
DEPLOYER_ADDR=0xYOUR_NEW_DEPLOYER_ADDRESS

# Sponsor/relayer EOA to authorize during wiring (optional; skipped if unset).
SPONSOR_ADDRESS=0xYOUR_SPONSOR_ADDRESS

# RPC + verification
ARB_SEPOLIA_RPC=https://arb-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
ARBISCAN_API_KEY=YOUR_ARBISCAN_KEY     # for --verify

# Deploy (pass the key on the CLI, do NOT commit it):
#   export DEPLOYER_ADDR=0x... ; export SPONSOR_ADDRESS=0x...
#   forge script script/DeployAll.s.sol:DeployAll \
#     --rpc-url $ARB_SEPOLIA_RPC --private-key 0xNEW_DEPLOYER_KEY \
#     --broadcast --verify
