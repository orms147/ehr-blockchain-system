# ===== Backend .env (EHR DATN) — copy to backend/.env and fill the secrets =====
# Synced to the 2026-06-19 redeploy. CRITICAL = lose it and data/access breaks.
# (This is a TEMPLATE — real secrets live in backend/.env, which is gitignored.)

# --- Database (Prisma / Postgres, e.g. Neon) --- CRITICAL
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require&channel_binding=require"

# --- Server ---
NODE_ENV=development            # "production" makes secret checks fail-fast (e.g. CREDENTIAL_ENCRYPTION_KEY)
PORT=3001
ENABLE_TEST_ROUTES=false        # "true" ONLY in local dev — mounts /api/test/* (forge JWT / reset-db). Never in shared/prod.
LOG_LEVEL=info
FRONTEND_URL=http://localhost:8081

# --- Auth (JWT) --- CRITICAL (self-generated; not fetched from any service)
JWT_SECRET=CHANGE_ME_openssl_rand_-hex_32
JWT_EXPIRES_IN=7d

# --- Blockchain (Arbitrum Sepolia, chainId 421614) — REDEPLOYED 2026-06-19, verified on Arbiscan ---
RPC_URL=https://arb-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
CHAIN_ID=421614
ACCESS_CONTROL_ADDRESS=0xc6eA2543aAA3cE33bA8B944CAfA888E7a182251E
CONSENT_LEDGER_ADDRESS=0xC316eA3F00b093e0fc37Fc53883A0BA4C77B436A
RECORD_REGISTRY_ADDRESS=0x638365dd44361151A7eDC8f0bC3a396526882a69
EHR_SYSTEM_ADDRESS=0xc0448D65fD00E3aaFB1E2F07df2aa5ae2510DCf1
DOCTOR_UPDATE_ADDRESS=0x61cb8e14c299A9976f01760e33D701B385cFf766

# --- Relayer / gas sponsor --- CRITICAL (hot key — keep secret)
SPONSOR_PRIVATE_KEY=0xCHANGE_ME

# --- Credential encryption (DoctorCredential) --- CRITICAL (64-hex; production fails fast if missing/invalid)
CREDENTIAL_ENCRYPTION_KEY=CHANGE_ME_64_hex_chars

# --- IPFS (Pinata) ---
PINATA_JWT=YOUR_PINATA_JWT
PINATA_GATEWAY=https://YOUR-GATEWAY.mypinata.cloud   # backend needs the FULL https URL

# --- Subgraph (The Graph Studio) ---
SUBGRAPH_URL=https://api.studio.thegraph.com/query/120096/ehr/0.2.6
SUBGRAPH_POLL_MS=30000

# --- RPC tuning (optional; sane defaults in code) ---
ROLE_CACHE_TTL_MS=600000
RPC_TRANSPORT_RETRIES=0
RPC_TRANSPORT_RETRY_DELAY_MS=1000
RPC_CATCHUP_DELAY_MS=1000
RPC_CATCHUP_MAX_BLOCKS=2000
RPC_LOGS_CHUNK_SIZE=500
RPC_WATCH_POLL_MS=8000
